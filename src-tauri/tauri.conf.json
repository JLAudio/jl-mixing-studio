{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JL Mixing Studio",
  "version": "0.1.0",
  "identifier": "com.jlaudio.jlmixingstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JL Mixing Studio",
        "width": 1080,
        "height": 760,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost"
    }
  },
  "bundle": {
    "active": false
  }
}
